# ============================================================
# IMD Store Log System - Environment Variables
# Copy this file to .env.local and fill in the values
# ============================================================

# Neon PostgreSQL connection string (pooled URL for serverless)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require&pgbouncer=true"

# Direct URL for Prisma migrations (non-pooled)
DIRECT_URL="postgresql://user:password@host/dbname?sslmode=require"

# JWT secret - generate with: openssl rand -base64 64
JWT_SECRET="your-secret-here-min-32-chars-use-openssl-rand"

# Cookie name
COOKIE_NAME="imd_session"

# App URL (used for CORS / absolute redirects)
NEXT_PUBLIC_APP_URL="https://your-app.vercel.app"
